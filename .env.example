# Host-level vars used by docker-compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ganti-dengan-password-acak-yang-kuat
POSTGRES_DB=dbfinace

# Subject Alt Names yang dimasukkan ke self-signed cert.
# Tambahkan IP LAN host kamu agar bisa diakses dari HP / device lain.
# Format: DNS:nama.host,IP:1.2.3.4,...
CERT_CN=skripsi-finance.local
CERT_SANS=DNS:localhost,DNS:skripsi-finance.local,IP:127.0.0.1,IP:192.168.100.103
